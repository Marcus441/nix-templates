#!/usr/bin/env bash

# [NIX] Load the Flake development environment
# Optimized for nix-direnv caching if available
if has nix_direnv_version || type -p nix-direnv-reload >/dev/null; then
  use flake
else
  use nix
fi

# [TOOL] Enable Watch Mode
# Re-load the shell if the flake definition changes
watch_file flake.nix
watch_file flake.lock

# [BUILD] Layout configuration
# Isolates direnv artifacts to the .direnv/ directory
layout_nix

# [OPT] Optional: Silence direnv loading messages
# export DIRENV_LOG_FORMAT=""
